# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
.pnpm-store/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code — keep skills, ignore local-only state
.claude/settings.local.json
.claude/logs/
.claude/cache/
.claude/projects/
.claude/worktrees/

# meta-skill phase-2 scratch (gitignored by design, see SKILL.md)
.extract-ds-skill-scratch/

.pnpm-store
